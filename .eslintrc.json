{
  "env": {
    "es2020": true
  },
  "globals": {
    "SpreadsheetApp": "readonly",
    "CacheService": "readonly",
    "PropertiesService": "readonly",
    "LockService": "readonly",
    "UrlFetchApp": "readonly",
    "Utilities": "readonly",
    "MailApp": "readonly",
    "ContentService": "readonly",
    "Logger": "readonly",
    "Session": "readonly",

    "SHEET": "writable",
    "SS": "writable",
    "SCRIPT_START": "writable",

    "getConfig": "readonly",
    "callMisskeyApi": "readonly",
    "postNote": "readonly",
    "callLLM": "readonly",
    "cleanNoteText": "readonly",
    "loadNGWords": "readonly",
    "containsNGWord": "readonly",
    "filterTimelineNotes": "readonly",
    "logError": "readonly",
    "incrementCounter": "readonly",
    "isTimeSafe": "readonly",
    "isNightTime": "readonly",
    "isAIDailyLimitReached": "readonly",
    "getCharacterPrompt_": "readonly",
    "getCharacterSetting_": "readonly",
    "normalizeRelation": "readonly",
    "getAffinityRank_": "readonly",
    "getFallbackReply_": "readonly",
    "getConversationHistory_": "readonly",
    "saveConversationTurn_": "readonly",

    "processRandomPost": "readonly",
    "processEventPost": "readonly",
    "processWeekdayPost": "readonly",
    "processScheduledPost": "readonly",
    "processTimelinePost": "readonly",
    "processPollPost": "readonly",
    "processReaction": "readonly",
    "processHoroscope": "readonly",
    "runDailyMaintenance": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", {
      "varsIgnorePattern": "^(doPost|onOpen|mainDispatcher|setupSpreadsheet|validateConfig|manageApiTokens|runFollowSync|executeAutoDelete|processHoroscope|generateDialogues|SHEET|SS|SCRIPT_START|isTimeSafe|isNightTime|isAIDailyLimitReached|getConfig|callMisskeyApi|postNote|callLLM|cleanNoteText|loadNGWords|containsNGWord|filterTimelineNotes|logError|incrementCounter|getCharacterPrompt_|getCharacterSetting_|normalizeRelation|getAffinityRank_|getFallbackReply_|testProcessRandomPost|testProcessEventPost|testProcessWeekdayPost|testProcessScheduledPost|testProcessTimelinePost|testProcessPollPost|testProcessReaction|testProcessHoroscope|testRunDailyMaintenance)"
    }],
    "no-undef": "error",
    "no-redeclare": ["error", { "builtinGlobals": false }],
    "eqeqeq": ["error", "smart"],
    "curly": ["error", "multi-line"],
    "no-eval": "error"
  }
}
